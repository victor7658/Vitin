<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>Duende Verde</title>

    <style>
        body {
            margin: 0;
            background: #0f172a;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            height: 100vh;
            font-family: Arial, sans-serif;
        }

        h1 {
            color: #00ff88;
            margin-bottom: 20px;
        }

        .gif-container {
            border: 3px solid #00ff88;
